@page
@model ConsultantIntelligenceModel
@{
    ViewData["Title"] = "Competitive Intelligence";
    ViewData["ActivePage"] = "ConsultantIntelligence";
}

<div class="d-flex align-items-baseline gap-3 mb-4">
    <h4 class="mb-0">Competitive Intelligence</h4>
    <span class="text-muted small">Consultant market share analytics — E-Rate FY2016–FY2026</span>
</div>

<!-- Overview stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="text-muted small">Active Consultants</div>
                <div class="fs-4 fw-bold">@Model.ConsultantCount.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-left:4px solid #198754">
            <div class="card-body">
                <div class="text-muted small">Total Applications</div>
                <div class="fs-4 fw-bold">@Model.ApplicationCount.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

@if (Model.ConsultantCount == 0)
{
    <div class="alert alert-info">
        No consultant data found. Run the consultant import jobs (<code>POST /import/consultants/applications</code>
        and <code>POST /import/consultants/frn-status</code>) to populate this dashboard.
    </div>
}
else
{
    <!-- Top consultants chart -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold">
                    Top 25 Consultants by Application Volume
                    <span class="text-muted fw-normal small">(grouped by EPC Organization ID)</span>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height:420px">
                        <canvas id="topConsultantsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top consultants table -->
    <div class="card">
        <div class="card-header fw-semibold">Consultant Market Leaders</div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Consultant</th>
                        <th>EPC ID</th>
                        <th class="text-end">Applications</th>
                        <th class="text-end">FRNs</th>
                        <th class="text-end">Funded Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="consultantTableBody">
                    <!-- Populated by JS from TopConsultantsJson -->
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
const consultants = @Html.Raw(Model.TopConsultantsJson);

function fmtDollars(v) {
    if (v == null) return '—';
    if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
    if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
    if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
    return '$' + v.toLocaleString();
}

function fmtNum(v) {
    return v == null ? '0' : v.toLocaleString();
}

function displayName(c) {
    return c.consultantName || c.consultantEpcOrganizationId;
}

if (consultants.length > 0) {
    // Chart
    new Chart(document.getElementById('topConsultantsChart'), {
        type: 'bar',
        data: {
            labels: consultants.map(c => displayName(c)),
            datasets: [{
                label: 'Applications',
                data: consultants.map(c => c.totalApplications),
                backgroundColor: 'rgba(13,110,253,0.75)',
                borderRadius: 3,
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.parsed.x.toLocaleString()} applications`
                    }
                }
            },
            scales: {
                x: { ticks: { callback: v => v.toLocaleString() } }
            }
        }
    });

    // Table
    const tbody = document.getElementById('consultantTableBody');
    consultants.forEach((c, i) => {
        const row = document.createElement('tr');
        row.innerHTML = `
            <td class="text-muted">${i + 1}</td>
            <td><strong>${displayName(c)}</strong></td>
            <td><code class="text-muted" style="font-size:.8rem">${c.consultantEpcOrganizationId}</code></td>
            <td class="text-end">${fmtNum(c.totalApplications)}</td>
            <td class="text-end">${fmtNum(c.totalFrns)}</td>
            <td class="text-end">${fmtDollars(c.totalFundingAmount)}</td>
            <td class="text-end">
                <a href="/ConsultantDetail?epcId=${encodeURIComponent(c.consultantEpcOrganizationId)}"
                   class="btn btn-sm btn-outline-primary" style="font-size:.75rem; padding:.2rem .6rem">
                    Detail →
                </a>
            </td>`;
        tbody.appendChild(row);
    });
}
</script>
}
