@page
@model ConsultantIntelligenceModel
@{
    ViewData["Title"] = "Competitive Intelligence";
    ViewData["ActivePage"] = "ConsultantIntelligence";
    string eRateCentralId = ErateWorkbench.Infrastructure.ConsultantConstants.ERateCentralEpcId;
}

<div class="d-flex align-items-baseline gap-3 mb-3">
    <h4 class="mb-0">Competitive Intelligence</h4>
    <span class="text-muted small">Consultant market share analytics — E-Rate FY2016–FY2026</span>
</div>

<!-- Filter bar -->
<form method="get" class="mb-4">
    <div class="card">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-1 text-muted" style="font-size:.75rem">FUNDING YEAR</label>
                    <select name="years" multiple class="form-select form-select-sm" size="3"
                            onchange="this.form.submit()">
                        @foreach (var yr in Model.FilterOptions.FundingYears)
                        {
                            if (Model.Years?.Contains(yr) == true)
                            {
                                <option value="@yr" selected>FY@yr</option>
                            }
                            else
                            {
                                <option value="@yr">FY@yr</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-1 text-muted" style="font-size:.75rem">STATE</label>
                    <select name="state" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All States</option>
                        @foreach (var s in Model.FilterOptions.States)
                        {
                            if (Model.State == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm mb-1 text-muted" style="font-size:.75rem">SERVICE TYPE</label>
                    <select name="serviceType" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All Service Types</option>
                        @foreach (var st in Model.FilterOptions.ServiceTypes)
                        {
                            if (Model.ServiceType == st)
                            {
                                <option value="@st" selected>@st</option>
                            }
                            else
                            {
                                <option value="@st">@st</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2 align-items-end">
                    @if (Model.HasActiveFilters)
                    {
                        <a href="/ConsultantIntelligence" class="btn btn-sm btn-outline-secondary w-100">
                            Clear filters
                        </a>
                    }
                </div>
            </div>
            @if (Model.HasActiveFilters)
            {
                <div class="mt-2" style="font-size:.78rem; color:#6c757d">
                    Showing filtered results —
                    @if (Model.Years?.Length > 0)
                    {
                        <span>Years: @string.Join(", ", Model.Years.Select(y => "FY" + y))</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.State))
                    {
                        <span> · State: @Model.State</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.ServiceType))
                    {
                        <span> · Service: @Model.ServiceType</span>
                    }
                </div>
            }
        </div>
    </div>
</form>

<!-- Overview stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="text-muted small">Active Consultants</div>
                <div class="fs-4 fw-bold">@Model.ConsultantCount.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-left:4px solid #198754">
            <div class="card-body">
                <div class="text-muted small">Total Applications</div>
                <div class="fs-4 fw-bold">@Model.ApplicationCount.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-left:4px solid #6f42c1">
            <div class="card-body">
                <div class="text-muted small">Total FRNs</div>
                <div class="fs-4 fw-bold">@Model.FrnCount.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

@if (Model.ConsultantCount == 0)
{
    <div class="alert alert-info">
        No consultant data found. Run the consultant import jobs (<code>POST /import/consultants/applications</code>
        and <code>POST /import/consultants/frn-status</code>) to populate this dashboard.
    </div>
}
else
{
    <!-- Insight cards -->
    @if (Model.InsightLeaderName != null || Model.InsightConcentration != null)
    {
        <h6 class="text-uppercase text-muted fw-semibold mb-3" style="letter-spacing:.05em">Market Insights</h6>
        <div class="row g-3 mb-4">
            @if (Model.InsightLeaderName != null)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <div class="text-muted small text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.05em">Market Leader</div>
                            <div class="fw-semibold">@Model.InsightLeaderName</div>
                            <div class="text-muted" style="font-size:.8rem">@Model.InsightLeaderDetail</div>
                        </div>
                    </div>
                </div>
            }
            @if (Model.InsightFundingName != null)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <div class="text-muted small text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.05em">Top Funded</div>
                            <div class="fw-semibold">@Model.InsightFundingName</div>
                            <div class="text-muted" style="font-size:.8rem">@Model.InsightFundingDetail</div>
                        </div>
                    </div>
                </div>
            }
            @if (Model.InsightReachName != null)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <div class="text-muted small text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.05em">Widest Reach</div>
                            <div class="fw-semibold">@Model.InsightReachName</div>
                            <div class="text-muted" style="font-size:.8rem">@Model.InsightReachDetail</div>
                        </div>
                    </div>
                </div>
            }
            @if (Model.InsightConcentration != null)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 bg-light">
                        <div class="card-body">
                            <div class="text-muted small text-uppercase mb-1" style="font-size:.7rem; letter-spacing:.05em">Concentration</div>
                            <div class="fw-semibold text-warning-emphasis">@Model.InsightConcentration</div>
                            <div class="text-muted" style="font-size:.8rem">in this context</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- E-Rate Central callout -->
    @if (Model.ERateCentralIsInResults)
    {
        <div class="alert alert-primary d-flex gap-2 align-items-start mb-4" role="alert" style="font-size:.875rem">
            <span>★</span>
            <div>
                <strong>E-Rate Central</strong> appears in these results (EPC ID @eRateCentralId).
                Rows marked with ★ in the table below.
            </div>
        </div>
    }

    <!-- Top consultants chart -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header fw-semibold">
                    Top 25 Consultants by Application Volume
                    <span class="text-muted fw-normal small">(grouped by EPC Organization ID)</span>
                </div>
                <div class="card-body">
                    <div class="chart-container" style="height:420px">
                        <canvas id="topConsultantsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sort controls + table -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">Consultant Market Leaders</span>
            <div class="d-flex gap-1 align-items-center">
                <span class="text-muted small me-1">Sort by:</span>
                <button class="btn btn-sm btn-outline-secondary sort-btn active" data-sort="apps">Applications</button>
                <button class="btn btn-sm btn-outline-secondary sort-btn" data-sort="frns">FRNs</button>
                <button class="btn btn-sm btn-outline-secondary sort-btn" data-sort="share">Market Share</button>
                <button class="btn btn-sm btn-outline-secondary sort-btn" data-sort="funding">Funded</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Consultant</th>
                        <th>EPC ID</th>
                        <th class="text-end">Applications</th>
                        <th class="text-end">App Share</th>
                        <th class="text-end">FRNs</th>
                        <th class="text-end">FRN Share</th>
                        <th class="text-end">Funded Total</th>
                        <th class="text-end">States</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="consultantTableBody"></tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
const consultants = @Html.Raw(Model.TopConsultantsJson);
const eRateCentralId = '@eRateCentralId';

function fmtDollars(v) {
    if (v == null) return '—';
    if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
    if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
    if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
    return '$' + Number(v).toLocaleString();
}

function fmtNum(v) { return (v ?? 0).toLocaleString(); }
function fmtPct(v) { return (v ?? 0).toFixed(1) + '%'; }
function displayName(c) { return c.consultantName || c.consultantEpcOrganizationId; }
function isERateCentral(c) { return c.consultantEpcOrganizationId === eRateCentralId; }

if (consultants.length > 0) {
    // Chart — always ordered by application count
    const chartData = [...consultants].sort((a, b) => b.totalApplications - a.totalApplications);
    const bgColors = chartData.map(c =>
        isERateCentral(c) ? 'rgba(13,110,253,0.95)' : 'rgba(13,110,253,0.65)');

    const chart = new Chart(document.getElementById('topConsultantsChart'), {
        type: 'bar',
        data: {
            labels: chartData.map(c => displayName(c)),
            datasets: [{
                label: 'Applications',
                data: chartData.map(c => c.totalApplications),
                backgroundColor: bgColors,
                borderRadius: 3,
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => {
                            const c = chartData[ctx.dataIndex];
                            return [
                                ` ${ctx.parsed.x.toLocaleString()} applications (${fmtPct(c.applicationSharePct)} share)`,
                                ` ${fmtNum(c.totalFrns)} FRNs`,
                                ` ${fmtDollars(c.totalFundingAmount)} funded`
                            ];
                        }
                    }
                }
            },
            scales: { x: { ticks: { callback: v => v.toLocaleString() } } }
        }
    });

    // Table render
    let sortField = 'apps';
    function renderTable() {
        const sorted = [...consultants].sort((a, b) => {
            if (sortField === 'apps')    return b.totalApplications - a.totalApplications;
            if (sortField === 'frns')    return b.totalFrns - a.totalFrns;
            if (sortField === 'share')   return b.applicationSharePct - a.applicationSharePct;
            if (sortField === 'funding') return (b.totalFundingAmount ?? 0) - (a.totalFundingAmount ?? 0);
            return 0;
        });

        const tbody = document.getElementById('consultantTableBody');
        tbody.innerHTML = '';
        sorted.forEach((c, i) => {
            const star = isERateCentral(c)
                ? '<span title="E-Rate Central" style="color:#0d6efd; margin-right:.3rem">★</span>' : '';
            const row = document.createElement('tr');
            if (isERateCentral(c)) row.style.background = 'rgba(13,110,253,.04)';
            row.innerHTML = `
                <td class="text-muted">${i + 1}</td>
                <td>${star}<strong>${displayName(c)}</strong></td>
                <td><code class="text-muted" style="font-size:.78rem">${c.consultantEpcOrganizationId}</code></td>
                <td class="text-end">${fmtNum(c.totalApplications)}</td>
                <td class="text-end text-muted" style="font-size:.85rem">${fmtPct(c.applicationSharePct)}</td>
                <td class="text-end">${fmtNum(c.totalFrns)}</td>
                <td class="text-end text-muted" style="font-size:.85rem">${fmtPct(c.frnSharePct)}</td>
                <td class="text-end">${fmtDollars(c.totalFundingAmount)}</td>
                <td class="text-end">${c.distinctStateCount > 0 ? c.distinctStateCount : '—'}</td>
                <td class="text-end">
                    <a href="/ConsultantDetail?epcId=${encodeURIComponent(c.consultantEpcOrganizationId)}"
                       class="btn btn-sm btn-outline-primary" style="font-size:.72rem; padding:.15rem .5rem">
                        Detail →
                    </a>
                </td>`;
            tbody.appendChild(row);
        });
    }
    renderTable();

    // Sort buttons
    document.querySelectorAll('.sort-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.sort-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            sortField = btn.dataset.sort;
            renderTable();
        });
    });
}
</script>
}
