@page
@model AboutModel
@{
    ViewData["Title"] = "About";
    ViewData["ActivePage"] = "About";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h1 class="h3 mb-1">About</h1>
        <p class="text-muted mb-4">ERATE Workbench POC</p>

        <div class="card mb-4">
            <div class="card-body">
                <p class="mb-0">
                    This application shows where E-Rate execution breaks down, where advisors should focus,
                    and how to reason about the E-Rate lifecycle operationally.
                </p>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-3">Resources</h5>
                <ul class="list-unstyled mb-0">
                    <li>
                        <a href="https://github.com/steven-dracker/erate-workbench-poc/wiki"
                           target="_blank" rel="noopener noreferrer">
                            GitHub Wiki &rarr;
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
