@page
@model FilingWindowModel
@{
    ViewData["Title"] = "Filing Window";
    ViewData["ActivePage"] = "FilingWindow";

    bool isFy2026Partial = Model.Progress.Fy2026Count > 0;
    double fy2026Pct = Model.Progress.Fy2025Count > 0
        ? Math.Round((double)Model.Progress.Fy2026Count / Model.Progress.Fy2025Count * 100, 1)
        : 0;
}

<div class="d-flex align-items-baseline gap-3 mb-3">
    <h4 class="mb-0">Filing Window Analytics</h4>
    <span class="text-muted small">Program-wide certification timing, demand vs commitment, and application status — FY2020–FY2026</span>
</div>

@if (isFy2026Partial)
{
    <div class="alert alert-warning d-flex gap-2 align-items-start mb-4" role="alert" style="font-size:.9rem">
        <span style="font-size:1.1rem">⚠️</span>
        <div>
            <strong>FY2026 data is partial.</strong>
            The FY2026 filing window is open. Application counts and requested amounts will increase
            as applicants submit and certify. Trend comparisons to prior years should be treated as
            preliminary until the window closes.
        </div>
    </div>
}

<!-- FY2026 Progress Cards -->
@if (isFy2026Partial)
{
    <h6 class="text-uppercase text-muted fw-semibold mb-3" style="letter-spacing:.05em">FY2026 Filing Progress</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card stat-card h-100">
                <div class="card-body">
                    <div class="text-muted small">FY2026 Applications</div>
                    <div class="fs-4 fw-bold">@Model.Progress.Fy2026Count.ToString("N0")</div>
                    <div class="text-muted" style="font-size:.75rem">
                        @fy2026Pct% of FY2025 pace (@Model.Progress.Fy2025Count.ToString("N0") final)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100" style="border-left:4px solid #fd7e14">
                <div class="card-body">
                    <div class="text-muted small">FY2026 Requested</div>
                    <div class="fs-4 fw-bold">@FormatDollars((double)Model.Progress.Fy2026Requested)</div>
                    <div class="text-muted" style="font-size:.75rem">
                        FY2025 final: @FormatDollars((double)Model.Progress.Fy2025Requested)
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100" style="border-left:4px solid #6c757d">
                <div class="card-body">
                    <div class="text-muted small">FY2020 Note</div>
                    <div class="small mt-1">
                        FY2020 includes a certification spike in September–October 2020 due to the
                        USAC COVID-19 filing window extension (2,317 records). This may cause the
                        FY2020 curve to appear extended relative to other years.
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Submission Timing Histogram -->
<h6 class="text-uppercase text-muted fw-semibold mb-3" style="letter-spacing:.05em">Certification Timing</h6>

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold">
                Cumulative Applications Certified by Day of Year
                <span class="text-muted fw-normal small">(day 1 = January 1 of funding year; late-cert outliers excluded)</span>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height:380px">
                    <canvas id="timingChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Requested vs Committed -->
<h6 class="text-uppercase text-muted fw-semibold mb-3" style="letter-spacing:.05em">Demand vs Commitment</h6>

<div class="row g-4 mb-4">
    <!-- Requested vs Committed bar -->
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-semibold">
                Requested vs Committed by Year
                <span class="text-muted fw-normal small">(Form 471 demand vs USAC Funding Commitments)</span>
            </div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="reqVsCommChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Commitment rate -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold">Commitment Rate by Year</div>
            <div class="card-body">
                <div class="chart-container" style="height:280px">
                    <canvas id="commitRateChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Application Status Breakdown -->
<h6 class="text-uppercase text-muted fw-semibold mb-3" style="letter-spacing:.05em">Application Status</h6>

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-semibold">
                Application Status by Year
                <span class="text-muted fw-normal small">(rows with null status excluded)</span>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height:320px">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
const timingRaw   = @Html.Raw(Model.TimingJson);
const reqVsComm   = @Html.Raw(Model.RequestedVsCommittedJson);
const statusRaw   = @Html.Raw(Model.AppStatusJson);

function fmtDollars(v) {
    if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
    if (v >= 1e6) return '$' + (v / 1e6).toFixed(1) + 'M';
    if (v >= 1e3) return '$' + (v / 1e3).toFixed(0) + 'K';
    return '$' + v.toLocaleString();
}

// ── Cumulative timing chart ───────────────────────────────────────────────
// Group raw daily counts by year, then accumulate into cumulative series.
const yearColors = {
    2020: 'rgba(108,117,125,0.85)',   // grey  — COVID year, annotated
    2021: 'rgba(13,110,253,0.85)',
    2022: 'rgba(25,135,84,0.85)',
    2023: 'rgba(255,193,7,0.9)',
    2024: 'rgba(220,53,69,0.85)',
    2025: 'rgba(111,66,193,0.85)',
    2026: 'rgba(253,126,20,0.95)',    // orange — partial year
};

const byYear = {};
timingRaw.forEach(r => {
    if (!byYear[r.year]) byYear[r.year] = {};
    byYear[r.year][r.day] = (byYear[r.year][r.day] || 0) + r.count;
});

// Build a shared day axis covering the observed range
const allDays = timingRaw.map(r => r.day);
const maxDay = allDays.length ? Math.min(Math.max(...allDays), 120) : 120;
const dayLabels = Array.from({length: maxDay}, (_, i) => i + 1);

const timingDatasets = Object.keys(byYear).sort().map(year => {
    let cumulative = 0;
    const data = dayLabels.map(d => {
        cumulative += byYear[year][d] || 0;
        return cumulative;
    });
    return {
        label: 'FY' + year + (year == '2026' ? ' ⚠' : ''),
        data,
        borderColor: yearColors[year] || 'rgba(100,100,100,0.7)',
        backgroundColor: 'transparent',
        borderWidth: year == '2026' ? 3 : 1.5,
        borderDash: year == '2026' ? [6, 3] : [],
        pointRadius: 0,
        tension: 0.3,
    };
});

new Chart(document.getElementById('timingChart'), {
    type: 'line',
    data: { labels: dayLabels, datasets: timingDatasets },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, boxWidth: 20 } },
            tooltip: {
                callbacks: {
                    title: ctx => 'Day ' + ctx[0].label,
                    label: ctx => ' ' + ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString() + ' apps',
                }
            }
        },
        scales: {
            x: {
                title: { display: true, text: 'Day of Year (Jan 1 = Day 1)' },
                ticks: { maxTicksLimit: 15 }
            },
            y: {
                title: { display: true, text: 'Cumulative Applications' },
                ticks: { callback: v => v.toLocaleString() }
            }
        }
    }
});

// ── Requested vs Committed grouped bar ───────────────────────────────────
const rvYears = reqVsComm.map(d => 'FY' + d.year);

new Chart(document.getElementById('reqVsCommChart'), {
    type: 'bar',
    data: {
        labels: rvYears,
        datasets: [
            {
                label: 'Total Requested (Form 471)',
                data: reqVsComm.map(d => d.requested),
                backgroundColor: 'rgba(13,110,253,0.75)',
                borderRadius: 4,
            },
            {
                label: 'Total Committed (USAC)',
                data: reqVsComm.map(d => d.committed),
                backgroundColor: 'rgba(25,135,84,0.75)',
                borderRadius: 4,
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 } } },
            tooltip: { callbacks: { label: ctx => ' ' + ctx.dataset.label + ': ' + fmtDollars(ctx.parsed.y) } }
        },
        scales: {
            y: { ticks: { callback: v => fmtDollars(v) } }
        }
    }
});

// ── Commitment rate line ──────────────────────────────────────────────────
const rateData = reqVsComm.map(d =>
    d.requested > 0 ? Math.round(d.committed / d.requested * 100 * 10) / 10 : null
);

new Chart(document.getElementById('commitRateChart'), {
    type: 'bar',
    data: {
        labels: rvYears,
        datasets: [{
            label: 'Commitment Rate',
            data: rateData,
            backgroundColor: rateData.map(v =>
                v === null ? 'rgba(200,200,200,0.4)' :
                v >= 80 ? 'rgba(25,135,84,0.75)' :
                v >= 60 ? 'rgba(255,193,7,0.85)' : 'rgba(220,53,69,0.75)'
            ),
            borderRadius: 4,
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: ctx => ' ' + (ctx.parsed.y ?? '—') + '%' } }
        },
        scales: {
            y: {
                min: 0, max: 100,
                ticks: { callback: v => v + '%' }
            }
        }
    }
});

// ── Application Status stacked bar ───────────────────────────────────────
// Collect unique statuses across all years, assign colors
const allStatuses = [...new Set(statusRaw.map(r => r.status))];
const statusColors = [
    'rgba(25,135,84,0.8)',
    'rgba(13,110,253,0.8)',
    'rgba(255,193,7,0.85)',
    'rgba(220,53,69,0.8)',
    'rgba(108,117,125,0.75)',
    'rgba(111,66,193,0.8)',
    'rgba(253,126,20,0.8)',
    'rgba(13,202,240,0.8)',
];

// Build pivot: years × statuses
const statusYears = [...new Set(statusRaw.map(r => r.year))].sort((a,b) => a-b);
const statusByYearStatus = {};
statusRaw.forEach(r => {
    statusByYearStatus[r.year + '|' + r.status] = r.count;
});

const statusDatasets = allStatuses.map((st, i) => ({
    label: st,
    data: statusYears.map(y => statusByYearStatus[y + '|' + st] || 0),
    backgroundColor: statusColors[i % statusColors.length],
    borderRadius: 3,
}));

new Chart(document.getElementById('statusChart'), {
    type: 'bar',
    data: {
        labels: statusYears.map(y => 'FY' + y),
        datasets: statusDatasets,
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'bottom', labels: { font: { size: 11 }, boxWidth: 16 } },
            tooltip: {
                callbacks: {
                    label: ctx => ' ' + ctx.dataset.label + ': ' + ctx.parsed.y.toLocaleString()
                }
            }
        },
        scales: {
            x: { stacked: true },
            y: { stacked: true, ticks: { callback: v => v.toLocaleString() } }
        }
    }
});
</script>
}

@functions {
    static string FormatDollars(double v) =>
        v >= 1e9 ? $"${v / 1e9:F1}B" :
        v >= 1e6 ? $"${v / 1e6:F1}M" :
        v >= 1e3 ? $"${v / 1e3:F0}K" :
        $"${v:N0}";
}
