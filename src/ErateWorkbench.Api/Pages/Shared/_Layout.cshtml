@using ErateWorkbench.Api.Utilities
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — ERATE Workbench</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: -.5px; }
        .nav-link.active { font-weight: 600; }
        .stat-card { border-left: 4px solid #0d6efd; }
        .chart-container { position: relative; height: 340px; }
        .table th { white-space: nowrap; }
        .pagination-info { color: #6c757d; font-size: .875rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container-xl">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                <img src="/branding/logo-dark.svg" alt="ERATE Workbench POC" style="height:32px;width:auto;" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")"
                           asp-page="/Index">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Search" ? "active" : "")"
                           asp-page="/Search">School &amp; Library Search</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Analytics" ? "active" : "")"
                           asp-page="/Analytics">Analytics</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "ProgramWorkflow" ? "active" : "")"
                           asp-page="/ProgramWorkflow">Program Workflow</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "AdvisorPlaybook" ? "active" : "")"
                           asp-page="/AdvisorPlaybook">Advisor Playbook</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "RiskInsights" ? "active" : "")"
                           asp-page="/RiskInsights">Risk Insights</a>
                    </li>
                </ul>
                <div class="d-none align-items-center gap-2 me-3" id="workflow-nav-controls">
                    <span id="workflow-nav-saved"
                          class="navbar-text small"
                          style="color:#86efac; opacity:0; transition:opacity .3s; white-space:nowrap">
                        ✓ Saved
                    </span>
                    <button id="workflow-clear-btn"
                            type="button"
                            class="btn btn-sm btn-outline-secondary"
                            style="font-size:.75rem; padding:.2rem .6rem; color:#adb5bd; border-color:#495057">
                        Clear notes
                    </button>
                </div>
                <span class="navbar-text text-secondary small">
                    <a href="/swagger" class="text-secondary" target="_blank">Swagger UI</a>
                </span>
            </div>
        </div>
    </nav>

    <main class="container-xl pb-5">
        @RenderBody()
    </main>

    <footer class="border-top mt-5 py-4">
        <div class="container-xl text-center text-muted" style="font-size:.8rem; letter-spacing:.02em;">
            ERATE Workbench POC &bull; Version @AppVersionProvider.Version &bull; &copy; @DateTime.UtcNow.Year
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
