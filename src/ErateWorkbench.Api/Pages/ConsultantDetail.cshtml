@page
@model ConsultantDetailModel
@{
    var name = Model.Detail?.ConsultantName ?? Model.EpcId ?? "Unknown";
    ViewData["Title"] = name;
    ViewData["ActivePage"] = "ConsultantIntelligence";
}

<div class="mb-3">
    <a href="/ConsultantIntelligence" class="text-muted small">← Competitive Intelligence</a>
</div>

<div class="d-flex align-items-baseline gap-3 mb-4">
    <h4 class="mb-0">@name</h4>
    @if (Model.Detail?.ConsultantName != null)
    {
        <code class="text-muted" style="font-size:.85rem">@Model.Detail.ConsultantEpcOrganizationId</code>
    }
</div>

<!-- Summary stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card stat-card h-100">
            <div class="card-body">
                <div class="text-muted small">Total Applications</div>
                <div class="fs-4 fw-bold">@(Model.Detail?.TotalApplications.ToString("N0") ?? "0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100" style="border-left:4px solid #198754">
            <div class="card-body">
                <div class="text-muted small">Total FRNs</div>
                <div class="fs-4 fw-bold">@(Model.Detail?.TotalFrns.ToString("N0") ?? "0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100" style="border-left:4px solid #6f42c1">
            <div class="card-body">
                <div class="text-muted small">Total Funded Commitment</div>
                <div class="fs-4 fw-bold">
                    @if (Model.Detail?.TotalFundingAmount.HasValue == true)
                    {
                        @($"${Model.Detail.TotalFundingAmount.Value:N0}")
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </div>
                <div class="text-muted" style="font-size:.75rem">Funded FRNs only</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Year-over-year trend -->
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-semibold">Activity by Funding Year</div>
            <div class="card-body">
                <div class="chart-container">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Service type breakdown -->
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-semibold">FRNs by Service Type</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div class="chart-container" style="height:280px;width:100%">
                    <canvas id="serviceTypeChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- State breakdown -->
<div class="row g-4">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header fw-semibold">
                Applications by Applicant State
                <span class="text-muted fw-normal small">(where the school or library is located)</span>
            </div>
            <div class="card-body">
                <div class="chart-container" style="height:300px">
                    <canvas id="stateChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-header fw-semibold">State Breakdown</div>
            <div class="table-responsive" style="max-height:320px; overflow-y:auto">
                <table class="table table-sm mb-0">
                    <thead class="table-light sticky-top">
                        <tr><th>State</th><th class="text-end">Applications</th></tr>
                    </thead>
                    <tbody id="stateTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
const trends       = @Html.Raw(Model.TrendsJson);
const stateBreak   = @Html.Raw(Model.StateBreakdownJson);
const serviceTypes = @Html.Raw(Model.ServiceTypesJson);

// Year-over-year trend — grouped bar
new Chart(document.getElementById('trendChart'), {
    type: 'bar',
    data: {
        labels: trends.map(d => d.year),
        datasets: [
            {
                label: 'Applications',
                data: trends.map(d => d.applicationCount),
                backgroundColor: 'rgba(13,110,253,0.75)',
                borderRadius: 3,
            },
            {
                label: 'FRNs',
                data: trends.map(d => d.frnCount),
                backgroundColor: 'rgba(25,135,84,0.7)',
                borderRadius: 3,
            }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: { position: 'top', labels: { font: { size: 11 } } }
        },
        scales: {
            x: { stacked: false },
            y: { beginAtZero: true }
        }
    }
});

// Service type — doughnut
if (serviceTypes.length > 0) {
    const palette = ['#0d6efd','#198754','#6f42c1','#fd7e14','#0dcaf0','#ffc107','#dc3545','#6c757d'];
    new Chart(document.getElementById('serviceTypeChart'), {
        type: 'doughnut',
        data: {
            labels: serviceTypes.map(d => d.serviceTypeName),
            datasets: [{
                data: serviceTypes.map(d => d.frnCount),
                backgroundColor: palette,
                hoverOffset: 8,
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { size: 10 }, boxWidth: 12 } }
            }
        }
    });
}

// State breakdown — horizontal bar
if (stateBreak.length > 0) {
    new Chart(document.getElementById('stateChart'), {
        type: 'bar',
        data: {
            labels: stateBreak.map(d => d.state),
            datasets: [{
                label: 'Applications',
                data: stateBreak.map(d => d.applicationCount),
                backgroundColor: 'rgba(111,66,193,0.7)',
                borderRadius: 3,
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } }
        }
    });

    const tbody = document.getElementById('stateTableBody');
    stateBreak.forEach(d => {
        const row = document.createElement('tr');
        row.innerHTML = `<td>${d.state}</td><td class="text-end">${d.applicationCount.toLocaleString()}</td>`;
        tbody.appendChild(row);
    });
}
</script>
}
