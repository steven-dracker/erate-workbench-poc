@page
@model AdvisorPlaybookModel
@{
    ViewData["Title"] = "Advisor Playbook";
    ViewData["ActivePage"] = "AdvisorPlaybook";
}

<style>
    /* -----------------------------------------------------------------------
       Operating Summary Band
    ----------------------------------------------------------------------- */
    .apb-summary {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: .5rem;
        margin-bottom: 1.5rem;
    }
    .apb-summary-cell {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .375rem;
        padding: .6rem .875rem;
    }
    .apb-summary-cell.highlight {
        border-left: 3px solid #2563eb;
        background: #f0f7ff;
    }
    .apb-summary-label {
        font-size: .625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #94a3b8;
        margin-bottom: .2rem;
    }
    .apb-summary-value {
        font-size: .8125rem;
        font-weight: 600;
        color: #1e293b;
        line-height: 1.3;
    }

    /* -----------------------------------------------------------------------
       Journey Strip
    ----------------------------------------------------------------------- */
    .apb-journey {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .5rem;
        padding: .875rem 1.25rem;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0;
        margin-bottom: 1.5rem;
    }
    .apb-jstep {
        display: flex;
        align-items: center;
        gap: .35rem;
        padding: .3rem .4rem;
        border-radius: .3rem;
        font-size: .775rem;
        font-weight: 500;
        color: #94a3b8;
        white-space: nowrap;
    }
    .apb-jstep.complete { color: #15803d; }
    .apb-jstep.current  {
        color: #1d4ed8;
        font-weight: 700;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
    }
    .apb-jdot {
        width: .55rem; height: .55rem;
        border-radius: 50%;
        background: #cbd5e1;
        flex-shrink: 0;
    }
    .apb-jstep.complete .apb-jdot { background: #16a34a; }
    .apb-jstep.current  .apb-jdot { background: #2563eb; box-shadow: 0 0 0 3px #bfdbfe; }
    .apb-jarrow {
        color: #cbd5e1;
        font-size: .8rem;
        padding: 0 .15rem;
        user-select: none;
    }

    /* -----------------------------------------------------------------------
       Phase Execution Sections
    ----------------------------------------------------------------------- */
    .apb-phase {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .5rem;
        border-left: 5px solid transparent;
        margin-bottom: .875rem;
        overflow: hidden;
    }
    .apb-phase.is-current { box-shadow: 0 2px 8px rgba(37,99,235,.12); }
    .apb-phase-header {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .625rem 1rem;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }
    .apb-phase.is-current .apb-phase-header { background: #f0f7ff; border-bottom-color: #bfdbfe; }
    .apb-phase-num {
        width: 1.6rem; height: 1.6rem;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; font-weight: 700; color: #fff;
        flex-shrink: 0;
    }
    .apb-phase-title {
        font-weight: 600;
        font-size: .875rem;
        color: #1e293b;
        flex-grow: 1;
    }
    .apb-phase-timing {
        font-size: .75rem;
        color: #64748b;
        white-space: nowrap;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: .25rem;
        padding: .1em .5em;
    }
    .apb-state-badge {
        font-size: .65rem;
        font-weight: 700;
        padding: .15em .55em;
        border-radius: .25rem;
        white-space: nowrap;
    }
    .apb-state-complete { background: #dcfce7; color: #15803d; }
    .apb-state-current  { background: #dbeafe; color: #1d4ed8; }
    .apb-state-upcoming { background: #f1f5f9; color: #64748b; }
    .apb-owner-badge {
        font-size: .65rem;
        font-weight: 600;
        padding: .15em .5em;
        border-radius: 999px;
        color: #fff;
    }
    .apb-phase-body {
        display: grid;
        grid-template-columns: 2fr 3fr;
        gap: 0;
    }
    .apb-col-left {
        padding: .875rem 1rem;
        border-right: 1px solid #e2e8f0;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }
    .apb-col-right {
        padding: .875rem 1rem;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }
    .apb-sublabel {
        font-size: .625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #94a3b8;
        margin-bottom: .25rem;
    }
    .apb-objective {
        font-size: .8125rem;
        color: #334155;
        line-height: 1.5;
    }
    .apb-exit {
        font-size: .8rem;
        color: #475569;
        line-height: 1.45;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: .375rem;
        padding: .4rem .6rem;
    }
    .apb-task-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }
    .apb-task-list li {
        display: flex;
        align-items: flex-start;
        gap: .4rem;
        font-size: .8rem;
        color: #334155;
        line-height: 1.45;
    }
    .apb-task-list li::before {
        content: "›";
        color: #94a3b8;
        font-weight: 700;
        flex-shrink: 0;
        margin-top: .05rem;
    }
    .apb-risk-box {
        display: flex;
        align-items: flex-start;
        gap: .45rem;
        background: #fffbeb;
        border: 1px solid #fde68a;
        border-radius: .375rem;
        padding: .45rem .6rem;
        font-size: .775rem;
        color: #78350f;
        line-height: 1.4;
    }
    .apb-phase.is-danger .apb-risk-box {
        background: #fff5f5;
        border-color: #fecaca;
        color: #991b1b;
    }

    /* -----------------------------------------------------------------------
       Risk & Deadline Watch
    ----------------------------------------------------------------------- */
    .apb-risk-section {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .5rem;
        padding: 1rem 1.25rem;
        margin-top: 1.5rem;
    }
    .apb-risk-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .625rem;
        margin-top: .75rem;
    }
    .apb-risk-item {
        display: flex;
        align-items: flex-start;
        gap: .5rem;
        padding: .5rem .75rem;
        border-radius: .375rem;
        font-size: .8rem;
        line-height: 1.45;
    }
    .apb-risk-critical { background: #fff1f2; border: 1px solid #fecdd3; color: #9f1239; }
    .apb-risk-warning  { background: #fffbeb; border: 1px solid #fde68a; color: #78350f; }
    .apb-risk-info     { background: #f0f9ff; border: 1px solid #bae6fd; color: #075985; }
    .apb-risk-label {
        font-size: .6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        flex-shrink: 0;
        padding: .1em .4em;
        border-radius: .2rem;
        margin-top: .15rem;
    }
    .apb-risk-critical .apb-risk-label { background: #fecdd3; color: #9f1239; }
    .apb-risk-warning  .apb-risk-label { background: #fde68a; color: #78350f; }
    .apb-risk-info     .apb-risk-label { background: #bae6fd; color: #075985; }

    /* -----------------------------------------------------------------------
       Advisor Notes Placeholder
    ----------------------------------------------------------------------- */
    .apb-notes-section {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: .5rem;
        padding: 1rem 1.25rem;
        margin-top: 1rem;
    }
    .apb-notes-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .625rem;
        margin-top: .75rem;
    }
    .apb-notes-card {
        background: #fffbeb;
        border: 1px dashed #fcd34d;
        border-radius: .375rem;
        padding: .625rem .75rem;
        min-height: 5rem;
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }
    .apb-notes-card-label {
        font-size: .625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #92400e;
    }
    .apb-notes-placeholder-text {
        font-size: .775rem;
        color: #a16207;
        font-style: italic;
    }

    @@media (max-width: 991px) {
        .apb-summary       { grid-template-columns: repeat(3, 1fr); }
        .apb-phase-body    { grid-template-columns: 1fr; }
        .apb-col-left      { border-right: none; border-bottom: 1px solid #e2e8f0; }
        .apb-risk-grid     { grid-template-columns: 1fr; }
        .apb-notes-grid    { grid-template-columns: 1fr; }
    }
</style>

<!-- Page header -->
<div class="d-flex align-items-baseline gap-3 mb-4">
    <h4 class="mb-0">Advisor Playbook</h4>
    <span class="text-muted small">
        An operational view of the E-Rate funding lifecycle for advisors managing client work from intake through compliance.
    </span>
</div>

<!-- =========================================================================
     A. Operating Summary Band
     ========================================================================= -->
<div class="apb-summary">
    <div class="apb-summary-cell">
        <div class="apb-summary-label">Program Year</div>
        <div class="apb-summary-value">2026</div>
    </div>
    <div class="apb-summary-cell">
        <div class="apb-summary-label">Client</div>
        <div class="apb-summary-value">Example School District</div>
    </div>
    <div class="apb-summary-cell highlight">
        <div class="apb-summary-label">Current Phase</div>
        <div class="apb-summary-value" style="color:#1d4ed8">Funding Application (Form 471)</div>
    </div>
    <div class="apb-summary-cell">
        <div class="apb-summary-label">Overall Status</div>
        <div class="apb-summary-value">
            <span style="display:inline-flex;align-items:center;gap:.35rem">
                <span style="width:.45rem;height:.45rem;border-radius:50%;background:#d97706;display:inline-block;flex-shrink:0"></span>
                In Progress
            </span>
        </div>
    </div>
    <div class="apb-summary-cell">
        <div class="apb-summary-label">Next Deadline</div>
        <div class="apb-summary-value">Form 471 window — late March 2026</div>
    </div>
    <div class="apb-summary-cell">
        <div class="apb-summary-label">Recommended Next Action</div>
        <div class="apb-summary-value" style="font-weight:500;color:#374151">
            Certify and submit Form 471 in EPC
        </div>
    </div>
</div>

<!-- =========================================================================
     B. End-to-End Journey Strip
     ========================================================================= -->
<div class="apb-journey" role="list" aria-label="E-Rate lifecycle stages">
    @for (int i = 0; i < Model.Phases.Count; i++)
    {
        var p = Model.Phases[i];
        var stateClass = p.State switch
        {
            PlaybookState.Complete => "complete",
            PlaybookState.Current  => "current",
            _                      => "upcoming",
        };
        <div class="apb-jstep @stateClass" role="listitem">
            <div class="apb-jdot"></div>
            <span>@p.ShortLabel</span>
            @if (p.State == PlaybookState.Complete)
            {
                <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-label="Complete">
                    <circle cx="6" cy="6" r="6" fill="#16a34a"/>
                    <path d="M3.5 6l1.8 1.8L8.5 4.5" stroke="#fff" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            }
        </div>
        if (i < Model.Phases.Count - 1)
        {
            <span class="apb-jarrow" aria-hidden="true">›</span>
        }
    }
</div>

<!-- =========================================================================
     C. Phase Execution Sections
     ========================================================================= -->
<div class="mb-2 d-flex align-items-baseline gap-2">
    <h6 class="mb-0 fw-semibold" style="color:#374151">Phase Execution Guide</h6>
    <span class="text-muted" style="font-size:.775rem">Objective · Tasks · Risk · Exit criteria for each stage</span>
</div>

@foreach (var phase in Model.Phases)
{
    var stateClass   = phase.State == PlaybookState.Current  ? "is-current"
                     : phase.State == PlaybookState.Complete ? "is-complete"
                     : "is-upcoming";
    var dangerClass  = phase.Number == 4 ? "is-danger" : "";
    var stateBadge   = phase.State switch
    {
        PlaybookState.Complete => ("apb-state-complete", "✓ Complete"),
        PlaybookState.Current  => ("apb-state-current",  "● Active"),
        _                      => ("apb-state-upcoming",  "Upcoming"),
    };

    <div class="apb-phase @stateClass @dangerClass"
         style="border-left-color:@phase.AccentColor">

        <!-- Header row -->
        <div class="apb-phase-header">
            <div class="apb-phase-num" style="background:@phase.AccentColor">@phase.Number</div>
            <div class="apb-phase-title">@Html.Raw(phase.Title)</div>
            <span class="apb-state-badge @stateBadge.Item1">@stateBadge.Item2</span>
            <span class="apb-phase-timing">@phase.Timing</span>
            @foreach (var owner in phase.Owners)
            {
                <span class="apb-owner-badge" style="background:@OwnerBadge.Color(owner)">@owner</span>
            }
        </div>

        <!-- Body: left = Objective + Exit Criteria, right = Tasks + Risk -->
        <div class="apb-phase-body">

            <div class="apb-col-left">
                <div>
                    <div class="apb-sublabel">Objective</div>
                    <div class="apb-objective">@Html.Raw(phase.Objective)</div>
                </div>
                <div>
                    <div class="apb-sublabel">Exit Criteria</div>
                    <div class="apb-exit">@phase.ExitCriteria</div>
                </div>
            </div>

            <div class="apb-col-right">
                <div>
                    <div class="apb-sublabel">Key Tasks</div>
                    <ul class="apb-task-list">
                        @foreach (var task in phase.KeyTasks)
                        {
                            <li>@task</li>
                        }
                    </ul>
                </div>
                <div class="apb-risk-box">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2.2"
                         stroke-linecap="round" stroke-linejoin="round"
                         class="flex-shrink-0 mt-1" aria-hidden="true">
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                    <span>@phase.RiskNote</span>
                </div>
            </div>

        </div>
    </div>
}

<!-- =========================================================================
     D. Risk & Deadline Watch
     ========================================================================= -->
<div class="apb-risk-section">
    <div class="d-flex align-items-baseline gap-2 mb-1">
        <h6 class="mb-0 fw-semibold" style="color:#374151">Risk &amp; Deadline Watch</h6>
        <span class="text-muted" style="font-size:.775rem">Most consequential timing and compliance obligations across the lifecycle</span>
    </div>
    <div class="apb-risk-grid">
        <div class="apb-risk-item apb-risk-critical">
            <span class="apb-risk-label">Critical</span>
            <span><strong>PIA response window — 15 days:</strong> Every USAC Program Integrity Assurance inquiry must be answered within 15 calendar days. Non-response is treated as denial; appeal recourse is extremely limited.</span>
        </div>
        <div class="apb-risk-item apb-risk-critical">
            <span class="apb-risk-label">Critical</span>
            <span><strong>FCDL appeal deadline — 60 days:</strong> Appeals of denied or reduced FRNs must be filed within 60 days of the Funding Commitment Decision Letter date. No extensions exist after this window closes.</span>
        </div>
        <div class="apb-risk-item apb-risk-warning">
            <span class="apb-risk-label">Deadline</span>
            <span><strong>28-day competitive bidding window:</strong> Form 470 must remain posted for at least 28 calendar days. Signing a contract before the window closes — or any preferred-vendor contact during it — voids E-Rate eligibility.</span>
        </div>
        <div class="apb-risk-item apb-risk-warning">
            <span class="apb-risk-label">Deadline</span>
            <span><strong>Form 471 filing window — late March:</strong> The application window closes annually, typically in late March. Missing it forfeits E-Rate funding for the entire program year with no remedy.</span>
        </div>
        <div class="apb-risk-item apb-risk-warning">
            <span class="apb-risk-label">Deadline</span>
            <span><strong>BEAR invoice deadline — 120 days:</strong> BEAR invoices must be submitted within 120 days of service delivery or the FCDL date, whichever is later. Missed deadlines permanently forfeit the discount.</span>
        </div>
        <div class="apb-risk-item apb-risk-info">
            <span class="apb-risk-label">Retention</span>
            <span><strong>10-year document retention:</strong> All E-Rate records — contracts, bids, invoices, and certifications — must be retained for 10 years from the last date of service. USAC, FCC OIG, and state auditors may request records long after the program year closes.</span>
        </div>
    </div>
</div>

<!-- =========================================================================
     E. Advisor Notes / Working Context (placeholder)
     ========================================================================= -->
<div class="apb-notes-section">
    <div class="d-flex align-items-baseline gap-2 mb-1">
        <h6 class="mb-0 fw-semibold" style="color:#374151">Advisor Notes &amp; Open Items</h6>
        <span class="text-muted" style="font-size:.775rem">Working context — persistence coming in a future version</span>
    </div>
    <div class="apb-notes-grid">
        <div class="apb-notes-card">
            <div class="apb-notes-card-label">Open Action Items</div>
            <div class="apb-notes-placeholder-text">Track outstanding advisor tasks here…</div>
        </div>
        <div class="apb-notes-card">
            <div class="apb-notes-card-label">Client Communication Log</div>
            <div class="apb-notes-placeholder-text">Log key decisions and client contacts…</div>
        </div>
        <div class="apb-notes-card">
            <div class="apb-notes-card-label">Flags &amp; Concerns</div>
            <div class="apb-notes-placeholder-text">Note risks, PIA exposures, or timing concerns…</div>
        </div>
    </div>
</div>
