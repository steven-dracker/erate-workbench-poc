@page
@model ReleasesModel
@{
    ViewData["Title"] = "Release Notes";
    ViewData["ActivePage"] = "Releases";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h1 class="h3 mb-1">Release Notes</h1>
        <p class="text-muted mb-4">ERATE Workbench POC</p>

        <div class="card">
            <div class="card-body">
                <p class="mb-3">
                    Full release history, changelogs, and downloadable artifacts are published on GitHub Releases.
                </p>
                <a href="https://github.com/steven-dracker/erate-workbench-poc/releases"
                   target="_blank" rel="noopener noreferrer">
                    View releases on GitHub &rarr;
                </a>
            </div>
        </div>
    </div>
</div>
